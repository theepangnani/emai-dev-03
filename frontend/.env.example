# Frontend environment variables
# Copy to .env.local for local development

# API base URL (defaults to window.location.origin if not set)
VITE_API_URL=http://localhost:8000

# Stripe publishable key (pk_test_xxx or pk_live_xxx)
# Used for any future client-side Stripe.js integrations
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# Firebase Cloud Messaging (web push notifications)
# Obtain from Firebase Console > Project Settings > General > Your apps
# Leave empty to disable web push — in-app notifications still work without these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VAPID key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=
